# .streamlit/secrets.toml
#
# DO NOT commit this file to version control.
# Add it to .gitignore and fill it in locally or via Streamlit Cloud's Secrets manager.
#
# --- Database ---
# Supabase (free tier):
#   1. Create a project at https://supabase.com
#   2. Go to Project Settings > Database
#   3. Copy the "Connection string" (URI format) and paste below
#
# Self-hosted Postgres (when you're ready):
#   Update the url value only. No application code changes required.
#
[database]
url = "postgresql://user:password@host:5432/dbname"

# --- Google OAuth ---
# Steps to obtain Google OAuth credentials:
#   1. Go to https://console.cloud.google.com
#   2. Create a project (or select an existing one)
#   3. Navigate to APIs & Services > Credentials
#   4. Click "Create Credentials" > "OAuth 2.0 Client ID"
#   5. Set application type to "Web application"
#   6. Add your redirect URI to "Authorised redirect URIs":
#        - Local:  http://localhost:8501/oauth2callback
#        - Cloud:  https://your-app.streamlit.app/oauth2callback
#   7. Copy the Client ID and Client Secret below

[auth]
redirect_uri  = "https://your-app.streamlit.app/oauth2callback"
cookie_secret = "replace-with-output-of-python3-c-import-secrets-print-secrets.token_hex-32"
# Optional: comma-separated list of permitted Google accounts.
# Omit (or leave blank) to allow any authenticated Google account.
# allowed_emails = "alice@example.com,bob@example.com"

[auth.google]
client_id           = "your-client-id.apps.googleusercontent.com"
client_secret       = "your-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
